# ==============================================================================
# Knpodly - Environment Configuration Example
# Copy to .env and fill in real values. Never commit .env.
# ==============================================================================

# --- General ---
ENVIRONMENT=production            # development | production
APP_NAME=Knpodly
APP_URL=https://labs.example.edu
LOG_LEVEL=INFO

# --- Security ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_HASH_SCHEME=bcrypt

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=knpodly
POSTGRES_USER=knpodly
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://knpodly:change-me@db:5432/knpodly

# --- Redis (task queue / session cache / websocket pub-sub) ---
REDIS_URL=redis://redis:6379/0

# --- Libvirt / Virtualization ---
LIBVIRT_DRIVER=qemu               # qemu | fake (fake = for local dev/tests, no real VMs)
LIBVIRT_URI=qemu:///system
VM_IMAGES_PATH=/srv/knpodly/VMImages
VM_ICONS_PATH=/srv/knpodly/VMIcons
VM_OVERLAY_PATH=/srv/knpodly/overlays
VM_NETWORK_BRIDGE=knpodly-labnet
VM_DEFAULT_RAM_MB=2048
VM_DEFAULT_VCPUS=2
VM_MAX_CONCURRENT_TOTAL=200

# --- Session / lifecycle policy ---
SESSION_MAX_DURATION_MINUTES=120
SESSION_EXPIRY_WARNING_MINUTES=15
SESSION_MAX_EXTENSION_MINUTES=60
SESSION_MAX_EXTENSIONS=1
IDLE_WARNING_MINUTES=15
IDLE_TIMEOUT_MINUTES=20

# --- noVNC / console ---
NOVNC_WS_BASE_PORT=6080
NOVNC_PUBLIC_BASE_URL=https://labs.example.edu/console

# --- Networking policy default ---
LAB_INTERNET_ACCESS_DEFAULT=restricted   # enabled | disabled | restricted

# --- Frontend (build-time) ---
VITE_API_BASE_URL=https://labs.example.edu/api/v1
VITE_WS_BASE_URL=wss://labs.example.edu/ws

# --- Email notifications (optional, future-proofing) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=knpodly@example.edu

# --- SSO / LDAP (optional, future-proofing, disabled by default) ---
AUTH_LDAP_ENABLED=false
AUTH_OAUTH2_ENABLED=false
AUTH_SAML_ENABLED=false
